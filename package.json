{
  "name": "grana-tracker",
  "private": true,
  "scripts": {
    "db": "docker compose up -d db",
    "db:stop": "docker compose down",
    "backend": "cd backend && go run cmd/server/main.go",
    "frontend": "cd frontend && npm run dev",
    "dev": "npm run db && concurrently -n api,web -c blue,green \"npm run backend\" \"npm run frontend\""
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.91",
    "concurrently": "^9.2.1"
  }
}
